# Neon Postgres — copy from your Neon dashboard (use the pooled connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# OpenAI — optional for v1. If missing, Clyde uses keyword-based mock classification
OPENAI_API_KEY=""

# The demo tenant ID (auto-created by seed script, paste UUID here after first seed)
DEMO_TENANT_ID=""

# Gmail OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3002/api/auth/gmail/callback"
GMAIL_TOKEN_SECRET=""
